# busqueda.tie
# Busca el valor máximo en una secuencia calculada.
# Demuestra: bucles, condicionales y acumuladores.
# Calcula el máximo de: 3, 7, 2, 9, 5
# Salida esperada: 9

let max = 0

let a = 3
if a > max:
    max = a

let b = 7
if b > max:
    max = b

let c = 2
if c > max:
    max = c

let d = 9
if d > max:
    max = d

let e = 5
if e > max:
    max = e

print max
